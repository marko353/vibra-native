{
  "expo": {
    "name": "Vibra Date",
    "slug": "vibra-date",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/launcher.webp",
    "scheme": "vibra-date",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/1000006401.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Aplikacija koristi Vašu lokaciju za prikaz relevantnog sadržaja i za funkcije navigacije."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/launcher.webp",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.marko353.vibradate"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

